{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "coffli-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "xxxxx"
    }
  ],
  "d1_databases": [
    {
      "binding": "D1",
      "database_name": "coffli-d1",
      "database_id": "xxxxx"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
